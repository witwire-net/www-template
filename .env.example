APP_ENV=development
APP_BEARER_TOKEN=dev-app-auth
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
PORT=8080

DATABASE_URL=postgres://template:template@localhost:5432/template?sslmode=disable
VALKEY_URL=redis://localhost:6379/0
VALKEY_KEY_PREFIX=www-template
OPENSEARCH_URL=http://localhost:9200

R2_ENDPOINT=http://localhost:9000
R2_REGION=us-east-1
R2_BUCKET=template
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_USE_PATH_STYLE=true

WEBAUTHN_RP_ID=localhost
ACCOUNT_RECOVERY_URL_BASE=http://localhost:5173/app/login/recovery/consume

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=noreply@example.com
