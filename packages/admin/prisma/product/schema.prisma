// Product DB 用 Prisma schema（読み取り専用参照）
// Product DB の admin_view スキーマと admin_op スキーマを Prisma Client で参照するための定義
// Prisma Migrate は適用せず、既存 golang-migrate 管理の構造を参照する

generator prisma-client-product {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/product-client"
}

datasource product_db {
  provider = "postgresql"
  url      = env("PRODUCT_DATABASE_URL")
  schemas  = ["admin_view"]
}

// admin_view.account_summaries: アカウント概要ビュー（読み取り専用）
// ビュー列名はベーステーブルと同じため @map は不要
model AccountSummary {
  id                    String    @id @map("id")
  email                 String    @map("email")
  status                String    @map("status")
  status_reason         String?   @map("status_reason")
  status_updated_at     DateTime? @map("status_updated_at")
  status_updated_by     String?   @map("status_updated_by")
  session_revoked_after DateTime? @map("session_revoked_after")
  created_at            DateTime  @map("created_at")
  passkey_count         BigInt    @map("passkey_count")

  @@map("account_summaries")
  @@schema("admin_view")
}

// admin_view.account_passkeys: アカウント passkey 情報ビュー（読み取り専用）
// ビューでは列名が passkey_id / passkey_identifier / passkey_created_at に alias されているため @map で対応する
model AccountPasskey {
  id                String   @id @map("passkey_id")
  account_id        String   @map("account_id")
  account_email     String   @map("account_email")
  identifier        String   @map("passkey_identifier")
  credential_handle String   @map("credential_handle")
  created_at        DateTime @map("passkey_created_at")
  public_key        Bytes    @map("public_key")
  sign_count        BigInt   @map("sign_count")
  aaguid            Bytes    @map("aaguid")
  backup_eligible   Boolean  @map("backup_eligible")
  backup_state      Boolean  @map("backup_state")
  transports        Json?    @map("transports")

  @@map("account_passkeys")
  @@schema("admin_view")
}
