# Admin Console 必須環境変数のサンプル
# 実際の値は .env に記載し、.env は git に含めないこと

# ── Admin DB ───────────────────────────────────────────────────────────────
ADMIN_DATABASE_URL=

# ── Product DB ─────────────────────────────────────────────────────────────
PRODUCT_DATABASE_URL=

# ── Valkey ────────────────────────────────────────────────────────────────
# Product auth と同じ Valkey infrastructure を共有し、logical DB 番号だけを分けること
# 例: Product は redis://localhost:6379/0、Admin は redis://localhost:6379/1
VALKEY_URL=
ADMIN_VALKEY_URL=

# ── OpenSearch ─────────────────────────────────────────────────────────────
OPENSEARCH_URL=
ADMIN_OPENSEARCH_AUDIT_REPLICAS=
ADMIN_OPENSEARCH_AUDIT_INDEX_PREFIX=
PRODUCT_OPENSEARCH_INDEX_PREFIX=

# ── Admin 公開 Origin ──────────────────────────────────────────────────────
ADMIN_ORIGIN=

# ── JWT Secret ─────────────────────────────────────────────────────────────
ADMIN_JWT_SECRET=

# ── 初回起動 Bootstrap ─────────────────────────────────────────────────────
# オペレーター 0 件時にのみ有効
ADMIN_BOOTSTRAP_ENABLED=
ADMIN_BOOTSTRAP_SECRET_HASH=
ADMIN_BOOTSTRAP_EXPIRES_AT=

# ── WebAuthn RP ────────────────────────────────────────────────────────────
ADMIN_RP_ID=
ADMIN_RP_NAME=

# ── Node 環境 ──────────────────────────────────────────────────────────────
NODE_ENV=development
