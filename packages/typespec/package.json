{
  "name": "@www-template/typespec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "tsp format .",
    "format:check": "tsp format . --check",
    "gen:openapi": "tsp compile .",
    "lint:openapi": "spectral lint openapi/openapi.json --ruleset .spectral.yaml --fail-severity error",
    "check": "pnpm format:check && tsp compile . --no-emit"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.15.0",
    "@typespec/compiler": "^1.8.0",
    "@typespec/http": "^1.8.0",
    "@typespec/openapi": "^1.8.0",
    "@typespec/openapi3": "^1.8.0"
  }
}
