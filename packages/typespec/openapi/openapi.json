  "components": {
    "schemas": {
      "AuthFailureClassification": {
        "type": "string",
        "enum": ["unauthenticated", "session-expired", "internal-error"]
      },
      "AuthFailureResponse": {
        "type": "object",
        "required": ["requestId", "error"],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "error": {
            "$ref": "#/components/schemas/AuthFailureClassification"
          }
        }
      },
      "AuthOperationErrorResponse": {
        "type": "object",
        "required": ["requestId", "error"],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "AuthSessionResponse": {
        "type": "object",
        "required": [
          "requestId",
          "accountId",
          "passkeyCredentialId",
          "sessionId",
          "sessionToken",
          "expiresAt"
        ],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "accountId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "passkeyCredentialId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "sessionId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "sessionToken": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "InvitationPasskeyRegisterRequest": {
        "type": "object",
        "required": ["invitation_session", "credential"],
        "properties": {
          "invitation_session": {
            "$ref": "#/components/schemas/UlidId"
          },
          "credential": {
            "type": "string"
          }
        }
      },
      "LogoutResponse": {
        "type": "object",
        "required": ["requestId", "revoked"],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "revoked": {
            "type": "boolean",
            "enum": [true]
          }
        }
      },
      "PasskeyFinishRequest": {
        "type": "object",
        "required": ["credential"],
        "properties": {
          "credential": {
            "type": "string"
          }
        }
      },
      "PasskeyRegisterRequest": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/RecoveryPasskeyRegisterRequest"
          },
          {
            "$ref": "#/components/schemas/InvitationPasskeyRegisterRequest"
          }
        ]
      },
      "PasskeyStartRequest": {
        "type": "object",
        "required": ["identifier"],
        "properties": {
          "identifier": {
            "type": "string"
          }
        }
      },
      "PasskeyStartResponse": {
        "type": "object",
        "required": ["requestId", "challenge", "rpId"],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "challenge": {
            "type": "string"
          },
          "rpId": {
            "type": "string"
          }
        }
      },
      "RecoveryAcceptedResponse": {
        "type": "object",
        "required": ["requestId", "accepted"],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "accepted": {
            "type": "boolean",
            "enum": [true]
          }
        }
      },
      "RecoveryConsumeRequest": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string"
          }
        }
      },
      "RecoveryConsumeResponse": {
        "type": "object",
        "required": [
          "requestId",
          "recoveryTokenId",
          "recoverySessionId",
          "recovery_session",
          "expiresAt"
        ],
        "properties": {
          "requestId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "recoveryTokenId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "recoverySessionId": {
            "$ref": "#/components/schemas/UlidId"
          },
          "recovery_session": {
            "$ref": "#/components/schemas/UlidId"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RecoveryPasskeyRegisterRequest": {
        "type": "object",
        "required": ["recovery_session", "credential"],
        "properties": {
          "recovery_session": {
            "$ref": "#/components/schemas/UlidId"
          },
          "credential": {
            "type": "string"
          }
        }
      },
      "RecoveryRequest": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        }
      },
      "StatusResponse": {
        "type": "object",
        "required": ["message", "timestamp"],
        "properties": {
          "message": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UlidId": {
        "type": "string",
        "description": "Canonical ULID string used for auth-owned resource and correlation identifiers."
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "Bearer"
      }
    }
  },
  "servers": [
    {
      "url": "/",
      "description": "Default server",
      "variables": {}
