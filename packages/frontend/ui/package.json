{
  "name": "@www-template-frontend/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./theme": {
      "types": "./src/theme.ts",
      "svelte": "./src/theme.ts",
      "default": "./src/theme.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "svelte": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*",
      "svelte": "./src/components/*",
      "default": "./src/components/*"
    },
    "./assets": {
      "types": "./src/assets/index.ts",
      "svelte": "./src/assets/index.ts",
      "default": "./src/assets/index.ts"
    },
    "./assets/*": {
      "types": "./src/assets/*",
      "svelte": "./src/assets/*",
      "default": "./src/assets/*"
    },
    "./layouts": {
      "types": "./src/layouts/index.ts",
      "svelte": "./src/layouts/index.ts",
      "default": "./src/layouts/index.ts"
    },
    "./layouts/*": {
      "types": "./src/layouts/*",
      "svelte": "./src/layouts/*",
      "default": "./src/layouts/*"
    },
    "./styles": {
      "types": "./src/styles/index.ts",
      "svelte": "./src/styles/index.ts",
      "default": "./src/styles/index.ts"
    },
    "./styles/*": {
      "types": "./src/styles/*",
      "svelte": "./src/styles/*",
      "default": "./src/styles/*"
    }
  },
  "svelte": "./src/index.ts",
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource/m-plus-1": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@tabler/icons-svelte": "^3.40.0",
    "@tanstack/svelte-virtual": "^3.13.23",
    "dompurify": "^3.3.1"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@storybook/svelte-vite": "^10.2.17",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^27.4.0",
    "sass-embedded": "^1.97.3",
    "storybook": "^10.2.17",
    "svelte": "^5.53.9",
    "svelte-check": "^4.4.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
