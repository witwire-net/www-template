{
  "name": "@www-template/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "svelte": "./src/components/index.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./src/components/*",
      "svelte": "./src/components/*",
      "default": "./src/components/*"
    },
    "./assets": {
      "types": "./src/assets/index.ts",
      "svelte": "./src/assets/index.ts",
      "default": "./src/assets/index.ts"
    },
    "./assets/*": {
      "types": "./src/assets/*",
      "svelte": "./src/assets/*",
      "default": "./src/assets/*"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "svelte": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./styles": {
      "types": "./src/styles/index.ts",
      "svelte": "./src/styles/index.ts",
      "default": "./src/styles/index.ts"
    }
  },
  "svelte": "./src/index.ts",
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.1.1",
    "@fontsource/m-plus-1": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@tabler/icons-svelte": "^3.40.0",
    "@tanstack/svelte-virtual": "^3.13.23",
    "dompurify": "^3.3.1"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^0.577.0",
    "@storybook/svelte-vite": "^10.2.17",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "latest",
    "@tanstack/table-core": "^8.21.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^3.2.4",
    "bits-ui": "^2.16.5",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "formsnap": "^2.0.1",
    "jsdom": "^27.4.0",
    "layerchart": "2.0.0-next.48",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "shadcn-svelte": "^1.2.7",
    "storybook": "^10.2.17",
    "svelte": "^5.53.9",
    "svelte-check": "^4.4.5",
    "svelte-sonner": "^1.1.0",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}
