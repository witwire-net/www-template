{
  "name": "@www-template/i18n",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./catalog": {
      "types": "./src/catalog.ts",
      "default": "./src/catalog.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "default": "./src/config.ts"
    },
    "./coverage": {
      "types": "./src/coverage.ts",
      "default": "./src/coverage.ts"
    },
    "./formatters": {
      "types": "./src/formatters.ts",
      "default": "./src/formatters.ts"
    },
    "./locales": {
      "types": "./src/locales.ts",
      "default": "./src/locales.ts"
    },
    "./translator": {
      "types": "./src/translator.ts",
      "default": "./src/translator.ts"
    }
  },
  "scripts": {
    "check": "tsc --noEmit -p ./tsconfig.json",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
