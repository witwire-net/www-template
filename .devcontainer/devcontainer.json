{
  "name": "www-template-devcontainer",
  "dockerComposeFile": "compose.yaml",
  "service": "workspace",
  "runServices": [
    "workspace",
    "postgres",
    "valkey",
    "opensearch",
    "minio",
    "mailpit",
    "otel-collector",
    "prometheus",
    "tempo",
    "loki",
    "grafana"
  ],
  "shutdownAction": "stopCompose",
  "workspaceFolder": "/workspaces/www-template",
  "remoteUser": "node",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "TOOLCHAIN_NODE_VERSION": "24.12.0",
    "TOOLCHAIN_PNPM_VERSION": "10.33.2",
    "TOOLCHAIN_SVELTEKIT_VERSION": "2.22.0",
    "TOOLCHAIN_ADAPTER_CLOUDFLARE_VERSION": "5.1.0",
    "TOOLCHAIN_GO_VERSION": "1.26.2",
    "TOOLCHAIN_GIN_VERSION": "1.11.0",
    "TOOLCHAIN_GORM_VERSION": "1.31.0",
    "TOOLCHAIN_GOLANG_MIGRATE_VERSION": "4.18.3",
    "TOOLCHAIN_OAPI_CODEGEN_VERSION": "2.4.1",
    "TOOLCHAIN_GOLANGCI_LINT_VERSION": "1.64.8",
    "TOOLCHAIN_TYPESPEC_VERSION": "1.8.0",
    "TOOLCHAIN_OPENSPEC_VERSION": "1.2.0"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.Go",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "typespec.typespec-vscode",
        "vitest.explorer",
        "usernamehw.errorlens",
        "christian-kohler.path-intellisense",
        "yoavbls.pretty-ts-errors",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "svelte.svelte-vscode"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "eslint.validate": ["javascript", "javascriptreact", "typescript", "typescriptreact"],
        "typescript.tsdk": "node_modules/typescript/lib",
        "typescript.enablePromptUseWorkspaceTsdk": true,
        "[go]": {
          "editor.defaultFormatter": "golang.go",
          "editor.formatOnSave": true
        },
        "go.useLanguageServer": true,
        "go.formatTool": "goimports",
        "go.lintTool": "golangci-lint",
        "go.lintOnSave": "package",
        "go.toolsManagement.autoUpdate": false,
        "go.testFlags": ["-count=1"],
        "typescript.tsserver.maxTsServerMemory": 1536,
        "files.watcherExclude": {
          "**/.git/objects/**": true,
          "**/node_modules/**": true,
          "**/dist/**": true,
          "**/.svelte-kit/**": true,
          "**/playwright-report/**": true,
          "**/test-results/**": true
        },
        "playwright.reuseBrowser": false,
        "playwright.showTrace": false
      }
    }
  },
  "forwardPorts": [24282, 3000, 3001, 5173, 8025, 8080, 8081, 9001, 9200],
  "portsAttributes": {
    "24282": {
      "label": "Serena Dashboard",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "Public Web",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Private Web",
      "onAutoForward": "notify"
    },
    "5173": {
      "label": "Frontend Dev Server",
      "onAutoForward": "silent"
    },
    "8025": {
      "label": "Mailpit UI",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Public Go API",
      "onAutoForward": "notify"
    },
    "8081": {
      "label": "Private Go API",
      "onAutoForward": "notify"
    },
    "9001": {
      "label": "MinIO Console",
      "onAutoForward": "notify"
    },
    "9200": {
      "label": "OpenSearch",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "bash .devcontainer/scripts/post-create.sh"
}
