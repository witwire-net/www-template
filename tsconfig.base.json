{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "paths": {
      "@www-template/app/*": ["packages/frontend/app/src/*"],
      "@www-template/web/*": ["packages/web/src/*"],
      "@www-template/domain": ["packages/frontend/domain/src/index.ts"],
      "@www-template/domain/hooks/auth/useAuthSession": [
        "packages/frontend/domain/src/hooks/auth/useAuthSession.svelte.ts"
      ],
      "@www-template/domain/hooks/auth/usePasskeyLogin": [
        "packages/frontend/domain/src/hooks/auth/usePasskeyLogin.svelte.ts"
      ],
      "@www-template/domain/hooks/auth/useRecoveryFlow": [
        "packages/frontend/domain/src/hooks/auth/useRecoveryFlow.svelte.ts"
      ],
      "@www-template/domain/hooks/auth/useSessionGuard": [
        "packages/frontend/domain/src/hooks/auth/useSessionGuard.svelte.ts"
      ],
      "@www-template/domain/hooks/status/useStatus": [
        "packages/frontend/domain/src/hooks/status/useStatus.svelte.ts"
      ],
      "@www-template/domain/*": ["packages/frontend/domain/src/*"],
      "@www-template/api/*": ["packages/frontend/api/src/*"],
      "@www-template/api": ["packages/frontend/api/src/index.ts"],
      "types": ["packages/frontend/domain/src/types/index.ts"],
      "types/*": ["packages/frontend/domain/src/types/*"],
      "@www-template/ui/styles": ["packages/frontend/ui/src/styles/index.ts"],
      "@ui": ["packages/frontend/ui/src"],
      "@ui/*": ["packages/frontend/ui/src/*"],
      "@www-template/ui/components": ["packages/frontend/ui/src/components/index.ts"],
      "@www-template/ui/*": ["packages/frontend/ui/src/*"],
      "@www-template/ui": ["packages/frontend/ui/src/index.ts"]
    },
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true
  },
  "exclude": ["node_modules", "dist", "build", ".wrangler"]
}
