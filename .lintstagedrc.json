{
  "*.{ts,tsx,js,jsx}": [
    "eslint --fix --no-inline-config --no-warn-ignored --max-warnings 0",
    "prettier --write"
  ],
  "*.css": ["stylelint --fix --max-warnings 0", "prettier --write"],
  "*.{json,md,yml,yaml}": ["prettier --write"],
  "*.go": ["bash scripts/hooks/format-staged-go.sh"],
  "{packages/backend/db/migrations,packages/admin/db/migrations}/*.sql": [
    "bash scripts/hooks/verify-staged-migrations.sh"
  ]
}
