{
  "name": "www-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "www-template monorepo with Svelte frontend, TypeSpec contract, and Go backend",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.12.0"
  },
  "scripts": {
    "dev:client": "pnpm dev:web",
    "dev:web": "pnpm --filter @www-template-frontend/web dev",
    "dev:app": "pnpm --filter @www-template-frontend/app dev",
    "dev:server": "go -C packages/backend run ./cmd/api",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev:web\" \"pnpm dev:app\"",
    "build:web": "pnpm --filter @www-template-frontend/web build",
    "build:app": "pnpm --filter @www-template-frontend/app build",
    "build:client": "pnpm build:web && pnpm build:app",
    "build:server": "bash scripts/go/build.sh",
    "build": "pnpm build:server && pnpm build:client",
    "check": "pnpm --filter @www-template/typespec check && pnpm --filter @www-template-frontend/web check && pnpm --filter @www-template-frontend/app check && pnpm --filter @www-template-frontend/ui check && bash scripts/go/build.sh",
    "gen": "pnpm gen:api-sdk && pnpm gen:backend",
    "gen:openapi": "pnpm --filter @www-template/typespec gen:openapi && prettier --write packages/typespec/openapi/openapi.json",
    "gen:swagger": "pnpm gen:openapi",
    "gen:api-sdk": "pnpm gen:openapi && pnpm --filter @www-template-frontend/api gen && prettier --write packages/frontend/api/src/generated/client.ts",
    "gen:backend": "bash scripts/go/gen-backend.sh",
    "check:codegen": "bash scripts/codegen/check.sh",
    "db:migrate:create": "bash scripts/go/migrate.sh create",
    "db:migrate:up": "bash scripts/go/migrate.sh up",
    "db:migrate:down": "bash scripts/go/migrate.sh down 1",
    "test": "pnpm test:run",
    "test:ui": "vitest --ui",
    "test:run": "pnpm --filter @www-template-frontend/web test && pnpm --filter @www-template-frontend/app test && pnpm --filter @www-template-frontend/ui test:run && bash scripts/go/test.sh",
    "test:coverage": "vitest run --coverage",
    "test:client": "pnpm --filter @www-template-frontend/web test && pnpm --filter @www-template-frontend/app test",
    "test:server": "bash scripts/go/test.sh",
    "test:ui-package": "vitest run --project frontend-ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "pnpm --filter @www-template/typespec lint:openapi && pnpm lint:eslint && bash scripts/go/lint.sh && bash scripts/security/lint-security.sh && pnpm check:codegen",
    "lint:eslint": "pnpm lint:eslint:root && pnpm lint:eslint:frontend && pnpm lint:eslint:ui",
    "lint:eslint:root": "eslint --no-inline-config --max-warnings 0 commitlint.config.js eslint.config.js playwright.config.ts vitest.config.ts scripts tests",
    "lint:eslint:frontend": "pnpm --filter @www-template-frontend/web exec svelte-kit sync && pnpm --filter @www-template-frontend/app exec svelte-kit sync && eslint --no-inline-config --max-warnings 0 packages/frontend/api packages/frontend/domain packages/frontend/app packages/frontend/web",
    "lint:eslint:ui": "eslint --no-inline-config --max-warnings 0 packages/frontend/ui",
    "format": "pnpm --filter @www-template/typespec format && prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" && bash scripts/go/format.sh",
    "format:check": "pnpm --filter @www-template/typespec format:check && prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" && bash scripts/go/format-check.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.0.3",
    "@vitest/ui": "^3.2.4",
    "concurrently": "^9.2.1",
    "dompurify": "^3.3.1",
    "eslint": "^9.39.2",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-deprecation": "^3.0.0",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-svelte": "^3.15.2",
    "eslint-plugin-unicorn": "^62.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.57.0"
  },
  "dependencies": {}
}
